# HearME Configuration
# Copy this file to .env and fill in your API keys.
# All keys are optional — the app works with just the free providers.

# Server
HEARME_PORT=8080
HEARME_HOST=localhost

# Tour Providers (uncomment to enable)
HEARME_BANDSINTOWN_APP_ID=

# HEARME_SONGKICK_API_KEY=sk_xxx
# HEARME_TICKETMASTER_API_KEY=tm_xxx

# Artist Providers
# HEARME_LASTFM_API_KEY=

# RSS Scraper
HEARME_SCRAPER_ENABLED=true
HEARME_SCRAPER_INTERVAL=30m
